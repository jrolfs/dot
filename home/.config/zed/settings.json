{
  "semantic_tokens": "off",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "theme": "Gruvbox Material Custom Dark",
  "vim_mode": true,
  "ui_font_size": 15,
  "buffer_font_size": 13,
  "ui_font_family": "IBM Plex Sans",
  "buffer_font_family": "JetBrains Mono",
  "format_on_save": "off",
  "relative_line_numbers": "enabled",
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 13,
    "font_fallbacks": ["JetBrainsMono Nerd Font", "FiraCode Nerd Font"]
  },
}
